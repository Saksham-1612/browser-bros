# MongoDB Configuration
# Optional - server works without MongoDB but caching/persistence requires it
# Use local: mongodb://localhost:27017
# Or Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_URI=mongodb+srv://saksham:<db_password>@blue.z0atsrx.mongodb.net/

# WebSocket Server Port
# Default: 12800
BROWSER_MCP_WS_PORT=12800

# HTTP Relay Mode
# If port is already in use, server automatically switches to HTTP relay
# No manual config needed - this is for reference only